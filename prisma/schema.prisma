generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id
  organizationId String?
  name         String
  email        String   @unique
  passwordHash String   @default("")
  role         String
  avatar       String
  createdAt    DateTime @default(now())
}

model Signal {
  id          String   @id
  source      String
  title       String
  location    String
  lat         Float
  lng         Float
  category    String
  severity    Int
  velocity    Int
  credibility Int
  sentiment   Int
  reach       Int
  timestamp   DateTime
  summary     String
}

model Team {
  id     String @id
  name   String
  role   String
  status String
}

model AuditLog {
  id             String   @id
  situationId    String
  time           DateTime
  reason         String
  recommendation String
}

model ApprovalRequest {
  id          String   @id
  situationId String
  statement   String
  status      String
  requestedBy String
  reviewer    String
  note        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlaybookTask {
  id          String   @id
  situationId String
  label       String
  owner       String
  eta         String
  priority    String
  status      String
  updatedAt   DateTime @updatedAt
}

model LiveEvent {
  id          String   @id
  type        String
  title       String
  message     String
  situationId String?
  createdAt   DateTime @default(now())
}

model Organization {
  id        String   @id
  name      String
  plan      String
  region    String
  createdAt DateTime @default(now())
}

model Incident {
  id             String   @id
  organizationId String?
  category       String
  title          String
  status         String
  owner          String
  severity       String
  publicStatus   String
  dueAt          DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model IncidentSignal {
  id         String   @id
  incidentId String
  signalId   String
  weight     Int
  createdAt  DateTime @default(now())
}

model SourceConnector {
  id        String   @id
  type      String
  name      String
  status    String
  config    String
  lastRunAt DateTime?
  createdAt DateTime @default(now())
}

model Notification {
  id          String   @id
  channel     String
  title       String
  message     String
  status      String
  situationId String?
  createdAt   DateTime @default(now())
}

model IncidentComment {
  id          String   @id
  situationId String
  author      String
  body        String
  internal    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Attachment {
  id          String   @id
  situationId String
  name        String
  kind        String
  url         String
  createdAt   DateTime @default(now())
}

model SavedReport {
  id          String   @id
  situationId String
  title       String
  format      String
  content     String
  createdBy   String
  createdAt   DateTime @default(now())
}
